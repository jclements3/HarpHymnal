{
  "title": "Not Worthy, Lord, to Gather Up the Crumbs",
  "key": "E♭ major",
  "key_root": "E-",
  "mode": "major",
  "meter": "4/4",
  "bpm": 100,
  "words": "Edward Henry Bickersteth, 1872",
