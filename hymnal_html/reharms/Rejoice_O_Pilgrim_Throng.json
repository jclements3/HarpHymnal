{
  "title": "Rejoice, O Pilgrim Throng",
  "key": "F major",
  "key_root": "F",
  "mode": "major",
  "meter": "4/4",
  "bpm": 100,
  "words": "Edward H. Plumptre, 1865",
  "music": "Arthur H. Messiter, 1883",
  "tune": "Marion",
  "lyrics": {
    "v1": "Rejoice, O pilgrim throng! Rejoice, give thanks, and sing; Your festal banner wave on high, The cross of Christ your King. Rejoice, rejoice, rejoice, Give thanks and sing.",
    "v2": "With all the angel choirs, With all the saints on earth, Pour out the strains of joy and bliss, True rapture, noblest mirth. Rejoice, rejoice, rejoice, Give thanks and sing.",
    "v3": "With voice as full and strong As ocean&#39;s surging praise, Send forth the hymns our fathers loved, The psalms of ancient days. Rejoice, rejoice, rejoice, Give thanks and sing.",
    "v4": "Still lift your standard high, Still march in firm array, As warriors through the darkness toil, Till dawns the golden day. Rejoice, rejoice, rejoice, Give thanks and sing.",
    "v5": "Yes, on through life&#39;s long path, Still chanting as ye go; From youth to age, by night and day, In gladness and in woe. Rejoice, rejoice, rejoice, Give thanks and sing."
  },
