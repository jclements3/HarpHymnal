{
  "title": "Alleluia, Sing To Jesus!",
  "key": "F major",
  "key_root": "F",
  "mode": "major",
  "meter": "3/4",
  "bpm": 100,
  "words": "William Chatterton Dix, 1867",
  "music": "Rowland H. Prichard, 1830",
