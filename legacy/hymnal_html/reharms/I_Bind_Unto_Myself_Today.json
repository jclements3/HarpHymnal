{
  "title": "I Bind Unto Myself Today",
  "key": "B♭ major",
  "key_root": "B-",
  "mode": "major",
  "meter": "3/4",
  "bpm": 100,
  "words": "attributed to St. Patrick of Ireland (circa 387-466). Paraphrased by Cecil F. Alexander, 1889",
  "music": "Charles V. Stanford, 1902",
  "tune": "St. Patricks Breastplate",
  "lyrics": {
    "v1": "I bind unto myself today The strong Name of the Trinity, By invocation of the same The Three in One and One in Three.",
    "v2": "I bind this day to me forever By power of faith, Christ&#39;s incarnation; His baptism in the Jordan river, His death on Cross for my salvation;",
    "v3": "I bind unto myself the power Of the great love of cheru- bim; The sweet &quot;Well done&quot; in judgment hour, The service of the sera- phim,",
    "v4": "I bind unto myself today The virtues of the star lit heaven, The glorious sun&#39;s life giving ray, The whiteness of the moon at even,",
    "v5": "I bind unto myself today The power of God to hold and lead, His eye to watch, His might to stay, His ear to hearken to my need."
  },
