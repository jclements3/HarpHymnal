{
  "title": "O That The Lord Would Guide My Ways",
  "key": "A♭ major",
  "key_root": "A-",
  "mode": "major",
  "meter": "3/2",
  "bpm": 100,
  "words": "Isaac Watts, 1719",
  "music": "or &#39;Eva&#39; William H. Havergal, 1847 Lowell Mason, 1850",
  "tune": "Evan",
  "lyrics": {
    "v1": "O that the Lord would guide my ways To keep His statutes still! O that my God would grant me grace To know and do His will!",
    "v2": "O send Thy Spirit down to write Thy law upon my heart! Nor let my tongue indulge deceit, Nor act the liar&#39;s part.",
    "v3": "From vani- ty turn off mine eyes; Let no corrupt design, Nor covetous desires arise Within this soul of mine.",
    "v4": "Order my footsteps by Thy Word, And make my heart sincere; Let sin have no dominion, Lord, But keep my conscience clear.",
    "v5": "Assist my soul, too apt to stray, A stricter watch to keep; And should I e&#39;er forget Thy way, Restore Thy wand&#39;ring sheep."
  },
