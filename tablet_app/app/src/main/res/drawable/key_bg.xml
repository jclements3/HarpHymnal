<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/kbd_key_pressed" />
            <corners android:radius="6dp" />
            <stroke android:width="1dp" android:color="@color/kbd_key_pressed" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/kbd_key_bg" />
            <corners android:radius="6dp" />
            <stroke android:width="1dp" android:color="@color/kbd_key_border" />
        </shape>
    </item>
</selector>
